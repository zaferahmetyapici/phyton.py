[app]
title = PatternPicnicMobile
package.name = patternpicnicmobile
package.domain = org.patternpicnic
source.dir = .
source.include_exts = py,png,jpg,kv,wav,mp3,json
version = 0.1
requirements = python3,kivy
orientation = portrait
fullscreen = 0
android.permissions = INTERNET
android.api = 34
android.build_tools_version = 34.0.0
android.skip_update = True
android.minapi = 24
android.archs = arm64-v8a, armeabi-v7a

[buildozer]
log_level = 2
warn_on_root = 1
